# Copy to .env and fill in. .env is gitignored; this template is committed.
# Consumed by tools/publish-edge.mjs (npm run publish:edge). In CI these are
# GitHub Actions repo secrets (EDGE_PRODUCT_ID / EDGE_CLIENT_ID / EDGE_API_KEY),
# NOT this file.

# --- Microsoft Edge Add-ons — Partner Center → Publish API ---
EDGE_PRODUCT_ID=         # product GUID (the GUID in the Partner Center dashboard URL)
EDGE_CLIENT_ID=          # Publish API Client ID  (Publish API → Create API credentials)
EDGE_API_KEY=            # Publish API key         (same page; has an expiry — rotate before it lapses)

# --- Optional overrides ---
# EDGE_PACKAGE=dist/chatpanel-extension.zip
# EDGE_NOTES=Same MV3 package as Chrome. Permission justifications in docs/web-store-permissions.md.
# EDGE_SKIP_PUBLISH=1     # upload+validate the draft only, do NOT submit for certification
