{
  "manifest_version": 3,
  "name": "ChatPanel — Privacy-First AI Agent",
  "version": "0.18.1",
  "description": "Works with Claude Code, Codex or any AI agents & local/remote models — a privacy-first side panel for meetings, chats & notes.",
  "minimum_chrome_version": "116",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "scripting",
    "activeTab",
    "contextMenus",
    "alarms",
    "identity",
    "downloads",
    "unlimitedStorage",
    "webNavigation",
    "debugger",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.zoom.us/wc/*",
        "https://meet.google.com/*",
        "https://teams.microsoft.com/*",
        "https://*.teams.microsoft.com/*",
        "https://teams.live.com/*",
        "https://*.teams.live.com/*",
        "https://*.webex.com/*"
      ],
      "js": [
        "content/adapter-zoom.js",
        "content/adapter-meet.js",
        "content/adapter-teams.js",
        "content/adapter-webex.js",
        "content/meeting-core.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.zoom.us/wc/*",
        "https://meet.google.com/*",
        "https://teams.microsoft.com/*",
        "https://*.teams.microsoft.com/*",
        "https://teams.live.com/*",
        "https://*.teams.live.com/*",
        "https://*.webex.com/*"
      ],
      "js": [
        "content/keep-visible.js"
      ],
      "all_frames": true,
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open ChatPanel (Cmd/Ctrl+I)"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+I",
        "mac": "Command+I"
      }
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "settings.html",
  "web_accessible_resources": [
    {
      "resources": [
        "content/flush-worker.js"
      ],
      "matches": [
        "https://*.zoom.us/*",
        "https://meet.google.com/*",
        "https://teams.microsoft.com/*",
        "https://*.teams.microsoft.com/*",
        "https://teams.live.com/*",
        "https://*.teams.live.com/*",
        "https://*.webex.com/*"
      ]
    }
  ],
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; style-src 'self' 'unsafe-inline'"
  }
}
